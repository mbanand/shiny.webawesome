#' Update a `{{TAG_NAME}}` component
#'
#' Generated update helper for the Web Awesome `{{TAG_NAME}}` component.
#'
#' @param session Shiny session object.
#' @param input_id Input id of the component to update.
{{PARAM_DOCS}}
#'
#' @return Invisibly returns `NULL`.
#'
#' @rdname {{RDNAME}}
#' @export
{{FUNCTION_NAME}} <- function(session,
                              input_id,
                              value = NULL,
                              label = NULL,
                              hint = NULL,
                              disabled = NULL) {
  message <- Filter(
    Negate(is.null),
    list(
      value = value,
      label = label,
      hint = hint,
      disabled = disabled
    )
  )

  session$sendInputMessage(input_id, message)
  invisible(NULL)
}
